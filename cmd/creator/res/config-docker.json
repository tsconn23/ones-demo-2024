{
    "mongo": {
      "host": "dcf-mongodb",
      "port": 27017,
      "username": "dbAdmin",
      "password": "password",
      "collection": "sampleData",
      "dbName": "dcf-mongodb"
    },
    "nextHop": {
      "host": "0.0.0.0",
      "port": 8090,
      "protocol": "http"
    },
    "sdk": {
      "layer": "app",
      "annotators": [
        "tpm",
        "pki"
      ],
      "hash": {
        "type": "sha256"
      },
      "signature": {
        "public": {
          "type": "ed25519",
          "path": "./res/keys/ed25519/public.key"
        },
        "private": {
          "type": "ed25519",
          "path": "./res/keys/ed25519/private.key"
        }
      },
      "stream": {
        "type": "mqtt",
        "config": {
          "clientId": "alvarium-test",
          "qos": 2,
          "user": "mosquitto",
          "password": "",
          "provider": {
            "host": "dcf-mqtt-broker",
            "protocol": "tcp",
            "port": 1883
          },
          "cleanness": false,
          "topics": [
            "alvarium-test-topic"
          ]
        }
      }
    },
    "logging": {
      "minLogLevel": "debug"
    }
  }